{
  "name": "@ubiquitypress/operas-metrics-widget",
  "version": "1.3.17",
  "repository": "https://github.com/ubiquitypress/operas-metrics-widget.git",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "check": "pnpm lint && pnpm typecheck && pnpm knip",
    "dev": "webpack serve --mode development",
    "build": "pnpm build:embed && pnpm build:npm && pnpm build:types",
    "build:embed": "webpack --mode production --progress",
    "build:npm": "webpack --config webpack.npm.config.js --mode production",
    "build:types": "tsc -p tsconfig.types.json",
    "format": "biome format --write .",
    "lint": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist/npm",
    "LICENSE",
    "readme.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/npm/types/src/react.d.ts",
      "import": "./dist/npm/index.js",
      "require": "./dist/npm/index.js"
    },
    "./widget.css": "./dist/npm/widget.css"
  },
  "types": "./dist/npm/types/src/react.d.ts",
  "main": "./dist/npm/index.js",
  "module": "./dist/npm/index.js",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "babel-loader": "^10.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "csstype": "^3.2.3",
    "knip": "^6.8.0",
    "lefthook": "^2.1.6",
    "preact": "^10.29.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "regenerator-runtime": "^0.14.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "semantic-release": "^25.0.3",
    "style-loader": "^4.0.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "pnpm": {
    "overrides": {
      "uuid": "^14.0.0"
    }
  },
  "dependencies": {
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "d3-geo": "^3.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "lucide-react": "^1.11.0",
    "mini-css-extract-plugin": "^2.10.2",
    "polished": "^4.3.1",
    "topojson-client": "^3.1.0",
    "ts-deepmerge": "^7.0.3",
    "twitter-widgets": "^2.0.0",
    "world-atlas": "^2.0.2"
  }
}
